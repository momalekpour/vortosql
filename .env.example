# Copy this file to .env in the project root directory and replace the values with your own.

# OpenAI (required if using OpenAI models)
OPENAI_API_KEY=your_openai_api_key

# Log level (optional): DEBUG, INFO, WARNING, ERROR — defaults to DEBUG
# Set to WARNING to suppress pipeline info logs in the CLI
LOG_LEVEL=WARNING

# PostgreSQL — matches the docker-compose postgres service defaults
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vortosql
POSTGRES_USER=vortosql
POSTGRES_PASSWORD=vortosql
